# Database (PostgreSQL - Railway provides this)
DATABASE_URL="postgresql://postgres:password@localhost:5432/election_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/election_db?schema=public"

# Auth secrets (CHANGE THESE IN PRODUCTION!)
NEXTAUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Server
PORT=3000
NODE_ENV="production"
